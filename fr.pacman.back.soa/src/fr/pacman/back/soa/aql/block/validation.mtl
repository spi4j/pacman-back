	+ '@OpÃĐration sans statut de retour@Attachez un code statut au paramÃĻtre de retour pour une opÃĐration'/]
	
[comment impossible d'avoir un service non rest (temporaire)./]
[query private err10 (s : soa::Service, o : soa::Operation)  : String = 'RG_10@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration sans exposition de dÃĐfinie@Attachez une exposition de type \'REST\' pour une opÃĐration'/]
	
[comment impossible d'avoir un service avec une fault sans code statut./]
[query private err11 (s : soa::Service, o : soa::Operation)  : String = 'RG_11@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@ParamÃĻtre \'fault\' sans statut@Attachez un code statut au paramÃĻtre \'fault\' pour une opÃĐration'/]
	
[comment impossible d'avoir un service paginÃĐ sans liste en sortie./]
[query private err12 (s : soa::Service, o : soa::Operation)  : String = 'RG_12@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration paginÃĐe sans liste en retour@DÃĐfinissez une liste en retour pour l\'opÃĐration'/]
	
[comment impossible d'avoir un service paginÃĐ sans liste en sortie./]
[query private err13 (s : soa::Service, o : soa::Operation)  : String = 'RG_13@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration paginÃĐe sans paramÃĻtre de pagination@DÃĐfinissez les paramÃĻtres page et size'/]
	
[comment impossible d'avoir un service paginÃĐ avec paramÃĻtre de pagination autre que Integer./]
[query private err14 (s : soa::Service, o : soa::Operation)  : String = 'RG_14@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration paginÃĐe avec un mauvais typage du paramÃĻtre de pagination@DÃĐfinissez le type \'Integer\' pour page et size'/]
	
[comment impossible d'avoir un service avec une URI qui se termine par '/'./]
[query private err15 (s : soa::Service, o : soa::Operation)  : String = 'RG_15@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration avec une mauvaise spÃĐcification pour l\'URI@Supprimer le caractÃĻre \'/\' prÃĐsent Ã  la fin de l\'URI'/]
	
[comment impossible d'avoir un service avec plusieurs paramÃĻtres passÃĐs dans le corps (body)./]
[query private err16 (s : soa::Service, o : soa::Operation)  : String = 'RG_16@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration avec plusieurs paramÃĻtres passÃĐs dans le corps (body)@Seul un paramÃĻtre est authorisÃĐ Ã  etre passÃĐ en \'body\''/]
	
[comment impossible d'avoir un service avec plusieurs paramÃĻtres en sortie./]
[query private err17 (s : soa::Service, o : soa::Operation)  : String = 'RG_17@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration avec plusieurs paramÃĻtres en sortie@Une opÃĐration ne peut avoir qu\'un seul paramÃĻtre en sortie'/]
	
[comment impossible d'avoir un service avec un ou des dtos passÃĐs ailleurs que dans le body./]
[query private err18 (s : soa::Service, o : soa::Operation)  : String = 'RG_18@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration avec un ou des dto(s) passÃĐ(s) hors body@Mofifier le type de passage pour le DTO'/]
	
[comment impossible d'avoir un service avec un binaire passÃĐ dans le path./]
[query private err19(s : soa::Service, o : soa::Operation)  : String = 'RG_19@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration avec un binaire passÃĐ dans le path@Mofifier le type de passage pour le binaire'/]
	
[comment impossible d'avoir un service avec le verbe trace (question de sÃĐcuritÃĐ)./]
[query private err20(s : soa::Service, o : soa::Operation)  : String = 'RG_20@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration avec le verbe TRACE@Cette option est dÃĐsactivÃĐe pour raisons de sÃĐcuritÃĐ'/]

[comment impossible d'avoir un service avec le verbe options et ded paramÃĻtres en entrÃĐe./]
[query private err21(s : soa::Service, o : soa::Operation)  : String = 'RG_21@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration avec le verbe OPTION@Supprimez les paramÃĻtres en entrÃĐe pour l\'opÃĐration'/]
	
[comment impossible d'avoir un service avec le verbe head et un paramÃĻtre en sortie./]
[query private err22(s : soa::Service, o : soa::Operation)  : String = 'RG_22@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration avec le verbe HEAD@Supprimez le(s) paramÃĻtre(s) en sortie pour l\'opÃĐration'/]
	
[comment impossible d'avoir un service avec des paramÃĻtres (dto) hÃĐritÃĐs./]
[query private err23(s : soa::Service, o : soa::Operation)  : String = 'RG_23@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration avec un (des) dto(s) hÃĐritÃĐ(s)@Supprimez le(s) paramÃĻtre(s) hÃĐritÃĐ(s) pour l\'opÃĐration'/]
	
[comment impossible pour l'instant de dÃĐfinir plusieurs components./]
[query private err24 (m : soa::System) : String = 'RG_24@' + m.nameObject() + '@Application modÃĐlisÃĐe avec plusieurs composants@Cette version de pacman ' 
  + ' n\'authorise pour l\'instant qu\'un seul composant'/]
  
[comment impossible pour l'instant de dÃĐfinir plusieurs sÃĐcuritÃĐs./]
[query private err25 (m : soa::System) : String = 'RG_25@' + m.nameObject() + '@Application modÃĐlisÃĐe avec plusieurs sÃĐcuritÃĐs@Cette version de pacman ' 
  + ' n\'authorise pour l\'instant qu\'une seule sÃĐcuritÃĐ'/]
  
[comment impossible de modÃĐliser une sÃĐcuritÃĐ oauth2 sans URL(s)./]
[query private err26 (s : soa::SecurityScheme) : String = 'RG_26@' + s.nameObject() + '@SÃĐcuritÃĐ modÃĐlisÃĐe sans URL dÃĐfinie'
  + '@ComplÃĐtez la dÃĐfinition de la sÃĐcuritÃĐ.'/]
  
[comment impossible de modÃĐliser une sÃĐcuritÃĐ oauth2 sans URL(s)./]
[query private err27 (s : soa::SecurityScheme) : String = 'RG_27@' + s.nameObject() + '@SÃĐcuritÃĐ non compatible avec la librairie'
  + '@Repositionnez la sÃĐcuritÃĐ sur OIDC'/]
  
[comment impossible de crÃĐer des opÃĐration avec des mÃĐtadonnÃĐes sans corps./]
[query private err28 (o : soa::Operation) : String = 'RG_28@' + o.nameObject() + '@OpÃĐration avec mÃĐtadonnÃĐe sans corps' 
  + '@Renseignez le corps obligatoire de la mÃĐtadonnÃĐe'/]
  
[comment impossible de crÃĐer des opÃĐration avec des mÃĐtadonnÃĐes sans corps./]
[query private err29 (s : soa::Service) : String = 'RG_29@' + s.nameObject() + '@Service avec mÃĐtadonnÃĐe sans corps' 
  + '@Renseignez le corps obligatoire de la mÃĐtadonnÃĐe'/]
  
[comment impossible de crÃĐer des opÃĐration avec des mÃĐtadonnÃĐes sans corps./]
[query private err30 (a : environment::Attribute) : String = 'RG_30@' + a.nameObject() + '@Attribut non prÃĐsent dans l\'entitÃĐ associÃĐe' 
  + '@Ajouter la mÃĐtadonnÃĐe Computed'/]
  
[comment impossible de passer un stream autrement que dans le body de la requÃŠte./]
[query private err31 (o : soa::Operation) : String = 'RG_31@' + o.nameObject() + '@Impossible de passer un stream hors du body' 
  + '@Modifier le passage de paramÃĻtre en body'/]
  
[comment impossible de passer un stream avec une multiplicitÃĐ sous forme de liste./]
[query private err32 (o : soa::Operation) : String = 'RG_32@' + o.nameObject() + '@Impossible de passer ou retourner une liste de streams' 
  + '@Supprimez la liste'/]
  
[comment impossible d'avoir un service S3 si opÃĐration n'est pas GET|POST|DELETE/]
[query private err33 (s : soa::Service) : String = 'RG_33@' + s.nameObject() + '@Un service S3 ne peut avoir que des opÃĐrations GET|POST|DELETE' 
  + '@Modifiez le verbe des opÃĐrations du service'/]
  
[comment impossible d'avoir des paramÃĻtres de type S3 si le service n'est pas un service S3/]
[query private err34 (s : soa::Service) : String = 'RG_34@' + s.nameObject() + '@Impossible d\'avoir des paramÃĻtres S3 si le service n\'est pas S3' 
  + '@Modifiez le service ou les paramÃĻtres'/]