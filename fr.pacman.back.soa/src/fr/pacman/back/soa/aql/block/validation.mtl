[module validation(	'http://www.obeonetwork.org/dsl/soa/4.0.0', 
					'http://www.obeonetwork.org/dsl/entity/3.0.0', 
					'http://www.obeonetwork.org/dsl/environment/3.0.0')/]

[import fr::pacman::back::core::aql::base/]
[import fr::pacman::back::core::aql::string/]
[import fr::pacman::back::core::aql::name::eobjects/]
[import fr::pacman::back::core::aql::query::eobject/]
[import fr::pacman::back::core::aql::query::attribute/]
[import fr::pacman::back::core::aql::query::parameter/]
[import fr::pacman::back::core::aql::query::service/]
[import fr::pacman::back::core::aql::query::operation/]
[import fr::pacman::back::core::aql::query::property/]
[import fr::pacman::back::core::aql::query::dto/]
[import fr::pacman::back::core::aql::validation::common/]
[import fr::pacman::back::core::validation::PacmanValidatorsReport/]
[import fr::pacman::back::core::property::project::ProjectProperties/]
[import fr::pacman::back::core::service::AnnotationUtils/]
[import fr::pacman::back::core::service::DtoEntityUtils/]

[comment ÃĐcriture du rapport de validation pour un fichier de modÃĐlisation (soa)./]
[comment pour les dtos on est pas reliÃĐ directement Ã  la base de donnÃĐes, doit on ÃŠtre plus souple sur les rÃĐfÃĐrences ?/]
[template public validation (m : soa::System)]
  [for (d | m.eAllContents(environment::DTO))]
    [comment pas de dto vide./]
    [if (d.attributesNoPK()->isEmpty())][d.add(d.err1())/][/if]
      
    [comment pas d'attribut avec identifier./] 
    [if (not d.attributesNoPK()->select(o | o.isIdentifier)->isEmpty())][d.add(d.err2())/][/if]
      
    [comment pas d'attribut avec (1,*) ou (0,*)./]
    [if (not d.attributesNoPK()->select(o | o.isMultiple())->isEmpty())][d.add(d.err3())/][/if]
      
    [comment pas d'attribut sans nom dÃĐfini./]
    [if (not d.attributesNoPK()->select(o | not o.name.exists())->isEmpty())][d.add(d.err4())/][/if]
      
    [comment pas d'attribut sans type dÃĐfini./]
    [if (not d.attributesNoPK()->select(o | not o.type.exists())->isEmpty())][d.add(d.err5())/][/if]
    
    [comment pas d'attribut non prÃĐsent dans l'entitÃĐ et sans annotation computed./]
    [if (d.isPersistent())]
      [let diff : Sequence(environment::Attribute) = d.get_attributes()
        ->select(a1 | not d.associatedEntity().get_attributes()->exists(a2 | a2.name = a1.name))]
        [if (not diff->isEmpty())][for (o | diff)][if (not o.has_metaComputed())][o.add(o.err30())/][/if][/for][/if]
      [/let]
    [/if]
    
    [comment pas d'hÃĐritage autre que des dtos/]
  [/for]
  
  [let dtss = m.superTypesDtos()]
  [for (s | m.providedServices())]
    [if (s.ownedInterface <> null)]
      [for (o | s.ownedInterface.ownedOperations)]
      [comment pas de service mappÃĐ sur une entitÃĐ./]
      [if (not o.output->select(o1 | o1.type.oclIsKindOf(entity::Entity))->isEmpty())][o.add(s.err7(o))/][/if]
        
      [comment pas de service sans paramÃĻtre de retour./]
      [if (o.output->isEmpty() and (o.mustHaveRsOutput()))][o.add(s.err8(o))/][/if]
        
      [comment pas de service sans code de retour./]
      [if (o.mustHaveRsOutput() and not o.output->first().statusCode.exists())][o.add(s.err9(o))/][/if]
        
      [comment pas de service non rest (temporaire)./]
      [if (not (o.exposition = soa::ExpositionKind::REST))][o.add(s.err10(o))/][/if]
        
      [comment pas de fault sans code de retour./]
      [if (not o.fault->select(f | not (f.statusCode.exists()))->isEmpty())][o.add(s.err11(o))/][/if]
        
      [comment pas de pagination sur une opÃĐration qui ne retourne pas une liste./]
      [if (o.paged and not o.output->first().isMultiple())][o.add(s.err12(o))/][/if]
        
      [comment pas de service paginÃĐ sans paramÃĻtres de pagination./]
      [if (o.paged and (not o.page.name.exists() or not o.size.name.exists()))][o.add(s.err13(o))/][/if]
        
      [comment pas de service paginÃĐ si les paramÃĻtres de pagination de sont pas des entiers./]
      [if (o.paged and not o.page.type.name.equalsIgnoreCase('integer'))][o.add(s.err14(o))/][/if]
        
      [comment pas de service paginÃĐ si les paramÃĻtres de pagination de sont pas des entiers./]
      [if (o.paged and not o.size.type.name.equalsIgnoreCase('integer'))][o.add(s.err14(o))/][/if]
        
      [comment pas de service avec un '/' Ã  la fin de l'URI (on pourrait le supprimer mais sensibilise le dÃĐvelopeur)./]
      [if (o.URI.exists() and '/'.equalsIgnoreCase(o.URI.last(1)))][o.add(s.err15(o))/][/if]
        
      [comment pas de service avec plusieurs paramÃĻtres passÃĐs dans le corps (body), c'est la norme (hormis s3)./]
      [if (o.input->select(o1 | s.isJpaService() and o1.restData.passingMode == soa::ParameterPassingMode::BODY)->size() > 1)]
        [o.add(s.err16(o))/][/if]
        
      [comment pas de service avec plusieurs paramÃĻtres de sortie./]
      [if (o.output->size() > 1)][o.add(s.err17(o))/][/if]
        
      [comment pas de service avec des dtos passÃĐs hors body (path ou query)/]
      [if (not o.input->select(o1 | o1.type.oclIsKindOf(environment::DTO) 
         and o1.restData.passingMode <> soa::ParameterPassingMode::BODY)->isEmpty())][o.add(s.err18(o))/][/if]
         
      [comment pas de service avec des binaires passÃĐs dans le path./]
      [if (not o.input->select(o1 | o1.type.name.equalsIgnoreCase('Binary') 
         and o1.restData.passingMode = soa::ParameterPassingMode::PATH)->isEmpty())][o.add(s.err19(o))/][/if]
         
      [comment pas de service avec TRACE (dÃĐsactivÃĐ pour raisons de sÃĐcuritÃĐ)./]
      [if (o.verb = soa::Verb::TRACE)][o.add(s.err20(o))/][/if]
        
      [comment pas de service OPTION avec des paramÃĻtres en entrÃĐe./]
      [if (o.verb = soa::Verb::OPTIONS and not o.input->isEmpty())][o.add(s.err21(o))/][/if]  
      
      [comment pas de service HEAD avec un paramÃĻtre en sortie./]
      [if (o.verb = soa::Verb::HEAD and not o.output->isEmpty())][o.add(s.err22(o))/][/if]  
      
      [comment pas de service avec un doute sur l'URI./]
      
      [comment pas de service avec des dtos hÃĐritÃĐs./]
      [if (o.input->exists(p | dtss->includes(p.type)) or dtss->includes(o.output) )][o.add(s.err23(o))/][/if]
        
      [comment vÃĐrification des mÃĐtadonnÃĐes (doit avoir un corps)./]
      [if (o.has_metaPermission() and not o.get_metaPermission().exists())][o.add(o.err28())/][/if]
      
      [comment vÃĐrification des mÃĐtadonnÃĐes (doit avoir un corps)./]
      [if (o.has_metaPermissionOr() and not o.get_metaPermissionOr().exists())][o.add(o.err28())/][/if]
      
      [comment vÃĐrification des mÃĐtadonnÃĐes (doit avoir un corps)./]
      [if (o.has_metaPermissionAnd() and not o.get_metaPermissionAnd().exists())][o.add(o.err28())/][/if]
      
      [comment vÃĐrification des mÃĐtadonnÃĐes (doit avoir un corps)./]
      [if (o.has_metaAuthToken() and not o.get_metaAuthToken().exists())][o.add(o.err28())/][/if]
      
      [comment pas de service avec des streams passÃĐs hors du body(on modifie Ã  la gÃĐnÃĐration)./]
      [if (o.input->exists(o1 | 'InputStream'.equalsIgnoreCase(o1.type.type()) 
         and o1.restData.passingMode <> soa::ParameterPassingMode::BODY))][o.add(o.err31())/][/if]
         
      [comment pas de service avec une liste de streams en sortie./]
      [if (o.output->exists(o1 | 'InputStream'.equalsIgnoreCase(o1.type.type()) 
         and o1.isMultiple()))][o.add(o.err32())/][/if]
         
      [comment pas de service avec une liste de streams en entrÃĐe./]
      [if (o.input->exists(o1 | 'InputStream'.equalsIgnoreCase(o1.type.type()) 
         and o1.isMultiple()))][o.add(o.err32())/][/if]
         
      [comment pas de service avec des paramÃĻtres S3 si le service n'est pas S3./]
      [if (s.isJpaService() and o.input->exists(o1 | o1.type.name.index('S3') <> -1))]
        [s.add(s.err34())/][/if]
           
      [comment impossible d'avoir un service S3 si opÃĐration n'est pas GET|POST|DELETE/]
      [if (s.isRsService() and s.operations()->exists(o1 | o1.verb <> soa::Verb::GET 
      	and o1.verb <> soa::Verb::POST and o1.verb <> soa::Verb::DELETE ))][s.add(s.err33())/][/if]
      [/for]
    [/if]
  [/for]
  [/let]
  [for (s | m.requiredServices())]
  [/for]
  [comment pas de multiples components internes pour l'instant/]
  [if (m.eAllContents(soa::Component)->size() > 1)][m.add(m.err24())/][/if]
    
  [comment pas de multiples sÃĐcuritÃĐs pour l'instant./]
  [if (m.eAllContents(soa::SecurityScheme)->size() > 1)][m.add(m.err25())/][/if]
    
  [if (m.eAllContents(soa::SecurityScheme)->size() > 0)]
    [let s = m.eAllContents(soa::SecurityScheme)->first()]
      [comment pas de sÃĐcuritÃĐ oauth2/oidc avec URL non dÃĐfinies./]
      [if (s.type = soa::SecuritySchemeType::OAUTH2 
        or s.type = soa::SecuritySchemeType::OPEN_ID_CONNECT)]
        [if (not s.connectURL.exists())][s.add(s.err26())/][/if]
      [/if]
      [comment pas librairie sso si pas oidc./]
      [if (m.isRsSSOAuthEnabled() 
        and s.type <> soa::SecuritySchemeType::OPEN_ID_CONNECT)]
        [s.add(s.err27())/]
      [/if]
    [/let]
 [/if]
[/template]

[comment impossible de crÃĐer des dtos sans attribut./]
[query private err1 (d : environment::DTO) : String = 'RG_01@' + d.nameObject() + '@Dto sans aucun attribut@Ajoutez au moins un attribut au niveau du dto'/]

[comment impossible de crÃĐer des dtos avec un attribut de type 'Identifier'./]
[query private err2 (d : environment::DTO) : String = 'RG_02@' + d.nameObject() + '@Dto avec un attribut marquÃĐ comme \'Identifier\'' +  
  '@Ne pas marquer l\'attribut(s) et laisser le gÃĐnÃĐrateur gÃĐrer l\'identifiant du dto'/]
  
[comment impossible de crÃĐer des dtos avec une multiplicitÃĐ de type (0,*) ou (1,*)./]
[query private err3 (d : environment::DTO) : String = 'RG_03@' + d.nameObject() + '@Dto avec un attribut de multiplicitÃĐ (0,*) ou (1,*)' +  
  '@Supprimez la multiplicitÃĐ (0,*) ou (1,*) sur l\'attribut'/]
  
[comment impossible de crÃĐer des dtos avec un attribut sans nom./]
[query private err4 (d : environment::DTO) : String = 'RG_04@' + d.nameObject() + '@Dto avec un attribut sans nom' 
  + '@DÃĐfinissez un nom pour l\'attribut'/]
  
[comment impossible de crÃĐer des dtos avec un attribut sans type./]
[query private err5 (d : environment::DTO) : String = 'RG_05@' + d.nameObject() + '@Dto avec un attribut sans type' 
  +  '@DÃĐfinissez un type pour l\'attribut' /]
  
[comment impossible de crÃĐer des dtos .............../]
[query private err6 (d : environment::DTO) : String = 'RG_06@' + d.nameObject() + 'xxxxxxxxx' /]
 
[comment impossible d'avoir un service directement mappÃĐ sur des entitÃĐs./]	
[query private err7 (s : soa::Service, o : soa::Operation)  : String = 'RG_07@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@Service rÃĐfÃĐrencant une (ou plusieurs) entitÃĐ(s)@Ne rÃĐfÃĐrencez que des objets de transfert (dto) au niveau des services'/]

[comment impossible d'avoir un service sans paramÃĻtre de retour./]
[query private err8 (s : soa::Service, o : soa::Operation)  : String = 'RG_08@' + s.nameObject() + '.' + o.name() + '()' 
	+ '@OpÃĐration sans paramÃĻtre de retour@ModÃĐlisez un paramÃĻtre de retour pour une opÃĐration'/]
	
[comment impossible d'avoir un service sans statut de retour./]
