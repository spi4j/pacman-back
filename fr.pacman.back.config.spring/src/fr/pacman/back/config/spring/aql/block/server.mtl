[comment écriture de l'implémentation pour la configuration (surcharge) du sso keycloack (librairie du minarm)./]
[template public rsSSOLoginHandlerImpl(any : ecore::EObject)]
  [any.classHeader(any.namePackageApplicationBase())/]
  
  [any.defaultImports()/]
  import [any.namePackageProject()/].[any.namePackageInfrastructureBase()/].[any.nameClassRsSSOUserServiceItf()/];
  import org.springframework.context.annotation.Configuration;
  import org.springframework.beans.factory.annotation.Qualifier;
  import org.springframework.context.annotation.Bean;
  import org.springframework.security.web.authentication.AuthenticationSuccessHandler;
  import org.springframework.stereotype.Component;
  
  /**
   * Configuration Spring Security complémentaire pour la gestion du succès
   * d'authentification dans le cadre d'un SSO (ex. Keycloak) avec la librairie du
   * ministère des armées.
   * <p>
   * Cette configuration expose un {@link AuthenticationSuccessHandler} spécifique
   * permettant d'effectuer une validation applicative supplémentaire après une
   * authentification réussie au niveau du fournisseur d'identité.
   *
   * <p>
   * Le bean est exposé avec le qualifiant {@code "mycoLoginSuccessHandlerExtra"}
   * afin de pouvoir être référencé explicitement dans la configuration de
   * sécurité Spring.
   * </p>
   *
   * @author MINARM
   */
  @Configuration
  class [any.nameClassRsSSOLoginHandlerImpl()/] 
  {
  
    /**
     * Fournit un {@link AuthenticationSuccessHandler} exécuté après une
     * authentification réussie.
     * <p>
     * Ce handler réalise une vérification applicative de l'utilisateur courant.
     */ 
    @Bean
    @Qualifier("mycoLoginSuccessHandlerExtra")    AuthenticationSuccessHandler ['login success handler'.apply_methodDefault()/]([any.nameClassRsSSOUserServiceItf()/] ['user service'.apply_parameterMethodClassicIn()/]) {
        return (['req'.apply_variableDefault()/], ['res'.apply_variableDefault()/], ['auth'.apply_variableDefault()/]) -> {
           var current = ['user service'.apply_parameterMethodClassicIn()/].getCurrentUser();
           
           [protected ('mycoLoginSuccessHandlerExtra'.protectedId()) startTagPrefix('// ') endTagPrefix('// ')]
             if (current == null) {
                var session = req.getSession(false);
                if (session != null) session.invalidate();
                   org.springframework.security.core.context.SecurityContextHolder.clearContext();
                  res.sendError(  HttpServletResponse.SC_FORBIDDEN, "Utilisateur non autorisé");
              }
           [/protected]
       };
    }
  }
[/template]

[comment écriture de l'interface de service pour l'obtention d'un utilisateur dans le cas sso (librairie du minarm)./]
[template public rsSSOUserService(any : ecore::EObject)]
  [any.classHeader(any.namePackageInfrastructureBase())/]
  
  /**
   * Service applicatif permettant d'accéder à l'utilisateur courant
   * authentifié via le mécanisme de SSO.
   * <p>
   * Cette interface fait le lien entre le contexte de sécurité technique
   * (ex. Spring Security / fournisseur d'identité SSO) et la notion
   * d'utilisateur métier propre à l'application.
   * </p>
   *
   * <p>
   * L'implémentation est responsable de :
   * </p>
   * <ul>
   *   <li>résoudre l'utilisateur courant à partir du contexte de sécurité,</li>
   *   <li>effectuer les vérifications d'autorisation applicatives nécessaires,</li>
   *   <li>retourner {@code null} si l'utilisateur n'est pas autorisé à accéder
   *       à l'application.</li>
   * </ul>
   *
   * <p>
   * Cette abstraction permet de dissocier :
   * </p>
   * <ul>
   *   <li>l'authentification SSO (technique),</li>
   *   <li>la gestion des utilisateurs et des droits applicatifs.</li>
   * </ul>
   */
  public interface [any.nameClassRsSSOUserServiceItf()/] {
      ['l\'utilisateur courant ou null si non autorisé'.commentMultiLines()/]
      Object ['current user'.apply_methodGet()/]();
  }
[/template]

[comment écriture de l'implémentation de service pour l'obtention d'un utilisateur dans le cas sso (librairie du minarm)./]
[template public rsSSOUserServiceImpl(any : ecore::EObject)]
  [any.classHeader(any.namePackageInfrastructureBase())/]
  
  import org.springframework.security.core.context.SecurityContextHolder;
  import org.springframework.stereotype.Service;
  
  /**
   * Implémentation par défaut du service {@link [any.nameClassRsSSOUserServiceItf()/]}.
   * <p>
   * Cette classe fournit une implémentation minimale permettant l’intégration
   * avec le mécanisme d’authentification SSO Keycloak et le câblage automatique 
   * par Spring.
   */
  @Service
  public class [any.nameClassRsSSOUserServiceImpl()/] implements [any.nameClassRsSSOUserServiceItf()/] {
    
    @Override
    public Object ['current user'.apply_methodGet()/]() {
       
