[comment écriture de la classe pour le corps des erreurs d'authentification sur les api rest (http - apikey)./]
[template public rsAuthenticationEntryPointImpl(any : ecore::EObject)]
  [any.classHeader(any.namePackageApplicationBase())/]
  
  import java.io.IOException;
  import org.springframework.security.core.AuthenticationException;
  import org.springframework.security.web.AuthenticationEntryPoint;
  import org.springframework.stereotype.Component;
  import jakarta.servlet.ServletException;
  import jakarta.servlet.http.HttpServletRequest;
  import jakarta.servlet.http.HttpServletResponse;
  
  /**
   * [any.nameClassRsAuthenticationEntryPointImpl()/] est une implémentation personnalisée de
   * l'interface {@link AuthenticationEntryPoint}. Cette classe est utilisée pour
   * gérer les erreurs d'authentification, en envoyant une réponse JSON avec un
   * message d'erreur lorsqu'un utilisateur non authentifié tente d'accéder à une
   * ressource protégée.
   * 
   * Dans ce cas, une réponse HTTP avec un statut 401 (Unauthorized) est renvoyée,
   * et un message JSON est envoyé dans le corps de la réponse.
   * 
   * Cette classe est marquée comme un composant Spring afin qu'elle puisse être
   * injectée dans la configuration de sécurité.
   *
   * Cette classe est générée dès la création du projet et ne peut présumer de la
   * présence ou non d'une sécurité. A supprimer si le projet ne contient aucune
   * règle de sécurité concernant l'accès pour ses apis.
   * 
   * @author [any.nameAuthor()/]
   */
  @Component(value = "[any.nameClassRsAuthenticationEntryPointImpl()/]")
  public class [any.nameClassRsAuthenticationEntryPointImpl()/] implements AuthenticationEntryPoint {
  
    /**
     * Méthode appelée lorsqu'une tentative d'accès à une ressource protégée 
     * échoue en raison d'une authentification manquante ou incorrecte.
     * Elle renvoie une réponse HTTP 401 (Unauthorized) avec un message d'erreur 
     * dans le corps de la réponse en format JSON.
     * 
     * @param request La requête HTTP entrante.
     * @param response La réponse HTTP qui sera envoyée au client.
     * @param authException L'exception d'authentification qui a été levée.
     * @throws IOException Si une erreur d'entrée/sortie se produit lors de l'écriture de la réponse.
     * @throws ServletException Si une erreur liée à la servlet se produit.
     */
     @Override
     public void commence(HttpServletRequest ['request'.apply_parameterMethodClassicIn()/]
        , HttpServletResponse ['response'.apply_parameterMethodClassicIn()/], 
        AuthenticationException ['authException'.apply_parameterMethodClassicIn()/]) throws IOException, ServletException {
        
        [protected ('commence'.protectedId()) startTagPrefix('// ') endTagPrefix('// ')]
          
          ['response'.apply_parameterMethodClassicIn()/].setContentType("application/json;charset=UTF-8");
          ['response'.apply_parameterMethodClassicIn()/].setStatus(HttpServletResponse.SC_UNAUTHORIZED);
          ['response'.apply_parameterMethodClassicIn()/].getWriter().write("{\"message\": \"Veuillez vous identifier pour accéder à cette ressource.\"}");
          
        [/protected]
     }
  }
[/template]

[comment écriture de la classe d'implémentation pour la récupération des propriétés pour storage S3./]
[template public s3PropsImpl(any : ecore::EObject)]
    [any.classHeader(any.namePackageApplicationBase())/]
    
    import org.springframework.boot.context.properties.ConfigurationProperties;
    import org.springframework.stereotype.Component;
    
    /**
     * Propriétés de configuration pour la connexion à S3.
     * <p>
     * Cette classe centralise toutes les propriétés nécessaires pour
     * se connecter à un serveur S3 et gérer les buckets.
     * Les valeurs sont injectées depuis le fichier {@code application.properties}
     * via le préfixe {@code S3}.
     * <p>
     * Note : on n'utilise pas @Value sur la classe de configuration au niveau de chaque champ afin 
     * d'éviter les problèmes liés aux profils Spring actifs. L'utilisation de @ConfigurationProperties 
     * permet de garantir que toutes les propriétés sont correctement résolues quel que soit le profil.
     * </p>
     * <p>Propriétés attendues :</p>
     * <ul>
     *     <li>{@code s3.url} : URL du serveur S3 (ex: http://localhost:9000)</li>
     *     <li>{@code s3.access-key} : clé d'accès pour l'authentification</li>
     *     <li>{@code s3.secret-key} : clé secrète associée</li>
     *     <li>{@code s3.bucket} : nom du bucket par défaut</li>
     * </ul>
     *
     * @author [any.nameAuthor()/]
     */
    @Component
    @ConfigurationProperties(prefix = "s3")
    public class [any.nameClassStorageS3PropsImpl()/] {
      
      [comment ici ne surtout pas mettre les conventions de nommage sur les noms des attributs./]
      ['URL du serveur S3 (ex: http://localhost:9000)'.commentSingleLine()/]
      private String url;
      
      ['Clé d\'accès utilisée pour l\'authentification auprès du serveur S3'.commentSingleLine()/]
      private String accessKey;
      
      ['Clé secrète associée à la clé d\'accès'.commentSingleLine()/]
      private String secretKey;
      
      ['Nom du bucket utilisé par l\'application'.commentSingleLine()/]
      private String bucket;
      
     /**
      * Retourne l'URL du serveur S3.
      * 
      * @return l'URL du serveur S3 (ex: http://localhost:9000)
      */
      public String getUrl() {
        return [any.prefixAffectation()/]url;
      }
      
     /**
      * Définit l'URL du serveur S3.
      * 
      * @param url l'URL du serveur S3 (ex: http://localhost:9000)
      */
      public void ['url'.apply_methodSet()/](String ['url'.apply_parameterMethodClassicIn()/]) {
        [any.prefixAffectation()/]url = url;
      }
      
     /**
      * Retourne la clé d'accès utilisée pour l'authentification auprès du serveur S3.
      * 
      * @return la clé d'accès
      */
      public String ['access key'.apply_methodGet()/]() {
        return [any.prefixAffectation()/]accessKey;
      }
      
     /**
      * Définit la clé d'accès utilisée pour l'authentification auprès du serveur S3.
      * 
      * @param ['access key'.apply_parameterMethodClassicIn()/] la clé d'accès
      */
      public void ['access key'.apply_methodSet()/](final String ['access key'.apply_parameterMethodClassicIn()/]) {
        [any.prefixAffectation()/]accessKey = ['access key'.apply_parameterMethodClassicIn()/];
      }
      
     /**
      * Retourne la clé secrète associée à la clé d'accès pour S3.
      * 
      * @return la clé secrète
      */
      public String ['secret key'.apply_methodGet()/]() {
        return [any.prefixAffectation()/]secretKey;
      }
      
     /**
      * Définit la clé secrète associée à la clé d'accès pour S3.
      * 
      * @param ['secret key'.apply_parameterMethodClassicIn()/] la clé secrète
      */
      public void ['secret key'.apply_methodSet()/](final String ['secret key'.apply_parameterMethodClassicIn()/]) {
       [any.prefixAffectation()/]secretKey = ['secret key'.apply_parameterMethodClassicIn()/];
      }
      
     /** 
      * Retourne le nom du bucket par défaut utilisé pour stocker les objets.
      * 
      * @return le nom du bucket
      */
      public String ['bucket'.apply_methodGet()/]() {
        return [any.prefixAffectation()/]bucket;
      }
      
     /**
      * Définit le nom du bucket par défaut utilisé pour stocker les objets.
      * 
      * @param ['bucket'.apply_parameterMethodClassicIn()/] le nom du bucket
      */
      public void ['bucket'.apply_methodSet()/](String ['bucket'.apply_parameterMethodClassicIn()/]) {
        [any.prefixAffectation()/]bucket = ['bucket'.apply_parameterMethodClassicIn()/];
      }
  }
[/template]

[comment écriture de la classe d'implémentation pour la configuration storage S3./]
[template public s3ConfigImpl(any : ecore::EObject)]
  [any.classHeader(any.namePackageApplicationBase())/]
  [protected ('imports'.protectedId()) startTagPrefix('// ') endTagPrefix('// ')]
    
    import org.springframework.beans.factory.annotation.Autowired;
    import org.springframework.boot.CommandLineRunner;
    import org.springframework.context.annotation.Primary;
    import org.springframework.context.annotation.Bean;
    import org.springframework.context.annotation.Configuration;
    
    import io.minio.BucketExistsArgs;
    import io.minio.MakeBucketArgs;
    import io.minio.MinioClient;
    
  [/protected]
  
  /**
   * Configuration Spring responsable de la création et de l'exposition
   * du {@link MinioClient} en tant que bean singleton dans le contexte
   * applicatif.
   * <p>
   * Les paramètres de connexion sont externalisés dans le fichier
   * {@code application.properties}. 
   * </p><p>
   * Actuellement, ce {@link CommandLineRunner} est très simple et ne gère pas les exceptions. 
   * Si quelque chose plante (par exemple, S3 n’est pas joignable, mauvaise URL, mauvais credentials, 
   * ou un problème réseau), Spring Boot va propager l'exception, ce qui entraînera l'échec du démarrage 
   * de l'application.
   * </p>
   * Le {@link MinioClient} est thread-safe et peut être injecté dans
   * les services métier pour effectuer des opérations de stockage
   * (upload, download, suppression d'objets).
   * </p>
   * @Author [any.nameAuthor()/] 
   */
  @Configuration
  public class [any.nameClassStorageS3ConfigImpl()/] {
  
      [protected ('attributes'.protectedId()) startTagPrefix('// ') endTagPrefix('// ')]
      [/protected]
      
      private final [any.nameClassStorageS3PropsImpl()/] ['props'.apply_attributeFinal()/];
      
      @Autowired
      public [any.nameClassStorageS3ConfigImpl()/]([any.nameClassStorageS3PropsImpl()/] ['props'.apply_parameterMethodClassicIn()/]) {
        [any.prefixAffectation()/]['props'.apply_attributeFinal()/] = ['props'.apply_parameterMethodClassicIn()/];
      }
      
      /**
       * Crée et configure l'instance du {@link S3Client}.
       *
       * @return instance singleton de {@link S3Client} injectée dans le contexte Spring
       */
      @Bean
      @Primary
      public MinioClient ['s3 client'.apply_methodDefault()/]() {
        
        [protected ('storage'.protectedId()) startTagPrefix('// ') endTagPrefix('// ')]
          
          return MinioClient.builder()
                  .endpoint([any.prefixAffectation()/]['props'.apply_attributeFinal()/].['url'.apply_methodGet()/]())
                  .credentials([any.prefixAffectation()/]['props'.apply_attributeFinal()/].['access key'.apply_methodGet()/](), 
                    [any.prefixAffectation()/]['props'.apply_attributeFinal()/].['secret key'.apply_methodGet()/]())
                  .build();
                  
        [/protected]
      }
      
     /**
      * Initialise le conteneur de stockage au démarrage de l'application.
      * <p>
      * Ce bean {@link CommandLineRunner} est exécuté automatiquement lors du
      * démarrage du contexte Spring. Il vérifie l'existence du conteneur de stockage
      * configuré et le crée s'il n'existe pas encore.
      * </p>
      * @param ['client'.apply_parameterMethodClassicIn()/] client de stockage utilisé pour interagir avec le serveur de
      *               stockage
      * @return une instance de {@link CommandLineRunner} exécutée au démarrage de
      *         l'application
      */
      @Bean
      public CommandLineRunner ['init bucket'.apply_methodDefault()/](MinioClient ['client'.apply_parameterMethodClassicIn()/]) {
          return args -> {
             boolean ['exists'.apply_variableDefault()/] = ['client'.apply_parameterMethodClassicIn()/].bucketExists(
                BucketExistsArgs.builder()
                     .bucket([any.prefixAffectation()/]['props'.apply_attributeFinal()/].['bucket'.apply_methodGet()/]())
                     .build());
             if (!['exists'.apply_variableDefault()/]) {
                ['client'.apply_parameterMethodClassicIn()/].makeBucket(
                     MakeBucketArgs.builder()
                        .bucket([any.prefixAffectation()/]['props'.apply_attributeFinal()/].['bucket'.apply_methodGet()/]())
                        .build());
               }
          };
      }
  }
[/template]

